# Variáveis usadas pelo docker-compose.yml.
# Copie este arquivo para .env e ajuste se quiser sobrescrever os padrões.
# Os valores abaixo batem com backend/src/main/resources/application.properties.exemplo.

# Banco de dados
POSTGRES_DB=trackfibra
POSTGRES_USER=trackfibra
POSTGRES_PASSWORD=trackfibra
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_JWT_SECRET_KEY=troque_por_uma_chave_secreta_com_pelo_menos_256_bits

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
